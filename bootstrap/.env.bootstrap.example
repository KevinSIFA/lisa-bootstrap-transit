# ============================================================================
# LISA — Template de configuration du bootstrap (a COMMITTER tel quel)
# ============================================================================
# Pour creer ta version reelle :
#   cp .env.bootstrap.example .env.bootstrap
#   # Puis remplis chaque valeur dans .env.bootstrap
#
# REGLE : .env.bootstrap doit etre dans .gitignore. Ce fichier .example
# reste un template propre, sans valeurs sensibles.
# ============================================================================


# ----------------------------------------------------------------------------
# 1. SERVEUR VPS
# ----------------------------------------------------------------------------
VPS_IP=
VPS_HOSTNAME=
VPS_TIMEZONE=Pacific/Noumea
ADMIN_EMAIL=


# ----------------------------------------------------------------------------
# 2. ANTHROPIC (Claude Opus + Sonnet)
# ----------------------------------------------------------------------------
# https://console.anthropic.com/settings/keys
# Compte Tier 2 ($40 prepayes) recommande des le demarrage.
ANTHROPIC_API_KEY=


# ----------------------------------------------------------------------------
# 3. GOOGLE CLOUD (Vertex AI Gemini + Drive)
# ----------------------------------------------------------------------------
# Compte de service unique pour Vertex AI ET Drive.
# Le fichier JSON sera depose sur le VPS a l'emplacement indique ci-dessous.
GOOGLE_CLOUD_PROJECT=
GOOGLE_SERVICE_ACCOUNT_JSON=/opt/lisa/secrets/lisa-service-account.json
GOOGLE_VERTEX_LOCATION=asia-southeast1


# ----------------------------------------------------------------------------
# 4. TELEGRAM (pilotage agent + alertes)
# ----------------------------------------------------------------------------
# Bot token via @BotFather, user IDs via @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=


# ----------------------------------------------------------------------------
# 5. TAILSCALE (acces SSH securise)
# ----------------------------------------------------------------------------
# https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=


# ----------------------------------------------------------------------------
# 6. GITHUB (catalogue scripts fournisseurs, push quotidien)
# ----------------------------------------------------------------------------
# URL SSH du repo prive + chemin DEPLOY KEY sur le VPS.
CATALOGUE_GIT_REMOTE=
CATALOGUE_GIT_DEPLOY_KEY=/opt/lisa/secrets/lisa_deploy_key
