# ============================================================================
# LISA — Checklist des clés à rassembler avant le bootstrap
# ============================================================================
# Comment l'utiliser :
#   1. Copie ce fichier en `.env.bootstrap` (sans le .example)
#   2. Remplis chaque ligne au fur et a mesure que tu obtiens les cles
#   3. NE COMMIT JAMAIS ce fichier. Il reste sur ton ordi.
#
# Statut de chaque cle :
#   [ ] = a faire
#   [x] = obtenu
# ============================================================================


# ----------------------------------------------------------------------------
# 1. SERVEUR VPS  (deja connu, on les fige ici)
# ----------------------------------------------------------------------------
+VPS_IP=XXX.XXX.XXX.XXX
VPS_HOSTNAME=srv1519973.hstgr.cloud
VPS_TIMEZONE=Pacific/Noumea
ADMIN_EMAIL=admin@example.com


# ----------------------------------------------------------------------------
# 2. ANTHROPIC  (Claude Opus 4.7 + Sonnet 4.6)
# ----------------------------------------------------------------------------
# Ou les creer : https://console.anthropic.com/settings/keys
# IMPORTANT : compte Tier 2 ($40 prepayes minimum) des le demarrage
# Suivi des couts : manuel via la console Anthropic (pas d'Admin API)
#
# [ ] ANTHROPIC_API_KEY              cle standard pour appels Opus/Sonnet
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXX-REPLACE-WITH-YOUR-KEY


# ----------------------------------------------------------------------------
# 3. GOOGLE CLOUD  (Gemini + Drive + Billing)
# ----------------------------------------------------------------------------
# Tu vas creer UN projet Google Cloud qui regroupe :
#   - L'API Gemini (via AI Studio)
#   - L'acces a Google Drive (compte de service)
#   - L'API Cloud Billing (suivi des couts Gemini)
#
# Ou : https://console.cloud.google.com
#
# Politique SIFA bloque les cles API : on utilise un compte de service unique
# pour Vertex AI (Gemini) ET Google Drive
#
# [ ] GOOGLE_CLOUD_PROJECT           ID du projet
# [ ] GOOGLE_SERVICE_ACCOUNT_JSON    chemin local vers le fichier .json
GOOGLE_CLOUD_PROJECT=lisa-496301
GOOGLE_SERVICE_ACCOUNT_JSON=C:\Users\kbramoulle\OneDrive - SIFA\Documents\Claude\Projects\LISA V2\secrets\lisa-service-account.json
GOOGLE_VERTEX_LOCATION=asia-southeast1   # Singapour, proche de Kuala Lumpur (VPS)


# ----------------------------------------------------------------------------
# 4. TELEGRAM  (pilotage agent + alertes)
# ----------------------------------------------------------------------------
# Ou les obtenir :
#   - Bot token : parle a @BotFather sur Telegram, commande /newbot
#   - User IDs  : parle a @userinfobot pour obtenir ton ID
#
# [ ] TELEGRAM_BOT_TOKEN             jeton du bot LISA
# [ ] TELEGRAM_ALLOWED_USER_IDS      tes ID Telegram (1 ou 2 admins max)
TELEGRAM_BOT_TOKEN=XXXXXXXXXX:XX-REPLACE-WITH-BOTFATHER-TOKEN

TELEGRAM_ALLOWED_USER_IDS=000000000


# ----------------------------------------------------------------------------
# 5. TAILSCALE  (admin SSH securise)
# ----------------------------------------------------------------------------
# Ou : https://login.tailscale.com/admin/settings/keys
# Genere une "auth key" reutilisable, pre-approuvee, sans expiration courte
#
# [ ] TAILSCALE_AUTH_KEY             cle d'authentification (tskey-auth-...)
TAILSCALE_AUTH_KEY=tskey-auth-XXXXXX-REPLACE-WITH-AUTH-KEY



# ----------------------------------------------------------------------------
# 6. GITHUB  (catalogue de scripts par fournisseur, push quotidien)
# ----------------------------------------------------------------------------
# 1. Cree un repo PRIVE sur le compte GitHub SIFA, ex: sifa-nc/lisa-catalogue
# 2. Genere une deploy key SSH (Settings → Deploy keys → Add deploy key)
#    avec droits ecriture activees
# 3. La cle PRIVEE correspondante sera deposee sur le VPS pendant le bootstrap
#
# [ ] CATALOGUE_GIT_REMOTE=git@github.com:YOUR-ORG/lisa-catalogue.git
# [ ] CATALOGUE_GIT_DEPLOY_KEY       chemin local vers la cle SSH privee
CATALOGUE_GIT_REMOTE=git@github.com:KevinSIFA/lisa-catalogue.git
CATALOGUE_GIT_DEPLOY_KEY=C:\Users\YOU\.ssh\lisa_deploy_key



# ============================================================================
# Fin du fichier — quand tout est rempli, on demarre l'execution du bootstrap
# ============================================================================
